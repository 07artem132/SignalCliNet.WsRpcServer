# Example: terminate TLS and expose the WebSocket JSON-RPC server as wss://.
# The container binds 127.0.0.1:9000 (see docker-compose.yml); nginx is the only
# thing reachable from the internet. Obtain certs with certbot/Let's Encrypt.
#
#   /etc/nginx/sites-available/wsrpc  ->  symlink into sites-enabled, then reload.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name signal-rpc.example.com;        # <-- your domain

    ssl_certificate     /etc/letsencrypt/live/signal-rpc.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/signal-rpc.example.com/privkey.pem;

    # The Chrome extension (potuzhnist) connects here as wss://signal-rpc.example.com/
    location / {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSockets are long-lived; raise idle timeouts.
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;

        # signal-cli attachments can be large; relax the body limit.
        client_max_body_size 110m;
    }
}

# Redirect plain HTTP to HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name signal-rpc.example.com;
    return 301 https://$host$request_uri;
}
